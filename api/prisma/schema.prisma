generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(cuid())
  username String    @unique
  email    String    @unique
  password String
  avatar   String?
  about    String?
  
  @@map("users")
}
