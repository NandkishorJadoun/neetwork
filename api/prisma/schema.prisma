generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(cuid())
  githubId   String    @unique
  username   String    @unique
  fullname   String?
  avatar     String?
  about      String?
  posts      Post[]
  comments   Comment[]
  likes      Like[]
  followers  Follow[]  @relation("followers")
  followings Follow[]  @relation("followings")

  @@map("users")
}

model Post {
  id         String    @id @default(cuid())
  text       String
  created_at DateTime  @default(now())
  author     User      @relation(fields: [userId], references: [id])
  userId     String
  comments   Comment[]
  likes      Like[]

  @@map("posts")
}

model Comment {
  id         String   @id @default(cuid())
  data       String
  created_at DateTime @default(now())
  author     User     @relation(fields: [userId], references: [id])
  userId     String
  post       Post     @relation(fields: [postId], references: [id])
  postId     String
}

model Like {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  post   Post   @relation(fields: [postId], references: [id])
  postId String
}

model Follow {
  id         String @id @default(cuid())
  senderId   User   @relation(fields: [fromId], references: [id], name: "followings")
  receiverId User   @relation(fields: [toId], references: [id], name: "followers")
  status     Status @default(PENDING)
  fromId     String
  toId       String
}

enum Status {
  PENDING
  ACCEPTED
}
